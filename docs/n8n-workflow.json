        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type",     "value": "application/json" },
            { "name": "X-Webhook-Secret", "value": "iouhJIFD8u9hfkJJOFJDJfoj8er4982nOIFHJd89f3h" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ document_id: $('Webhook').item.json.document_id, status: 'ready', scene_count: $('Collect Chunks').item.json.scene_count }) }}",
        "options": {}
      }
    }
  ],
