        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ status: 'ready', ready_at: new Date().toISOString(), scene_count: $('Collect Chunks').item.json.scene_count }) }}",
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "cred-supabase",
          "name": "Supabase Service Role"
        }
      }
    },
    {
      "id": "aaaaaaaa-0021-0000-0000-000000000000",
